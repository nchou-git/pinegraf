# External APIs
OPENAI_API_KEY=sk-...

# Database (Postgres for prod, SQLite for local dev)
DATABASE_URL=postgresql+psycopg://pinegraf:pinegraf@localhost:5432/pinegraf

# Admin auth
PINEGRAF_ADMIN_PASSWORD=pinegraf
PINEGRAF_ADMIN_COOKIE_SECRET=change-me-in-prod
SITE_AUTH_USER=pinegraf
SITE_AUTH_PASSWORD=change-me-in-prod

# Mock toggles: "true" for offline dev, "false" to hit real services
USE_MOCK_EXTRACT=true
USE_MOCK_QUERY=true
USE_MOCK_FETCH=true

# Crawler config (comma-separated for the list fields)
CRAWL_SEED_URLS=
CRAWL_SITEMAP_URLS=
CRAWL_ALLOWED_DOMAINS=
CRAWL_MAX_PAGES=500
CRAWL_MAX_DEPTH=2
