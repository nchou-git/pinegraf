# OpenAI API key for non-mock extraction, validation, synthesis, and query clients.
OPENAI_API_KEY=

# Admin login password for /admin/login.
PINEGRAF_ADMIN_PASSWORD=admin

# Secret used to sign the pinegraf_admin cookie value.
PINEGRAF_ADMIN_COOKIE_SECRET=dev-secret-change-me

# SQLAlchemy database URL. Use Postgres in production; SQLite is local/dev only.
DATABASE_URL=sqlite:///./pinegraf.db

# Use deterministic mock extraction/validation/synthesis clients.
USE_MOCK_EXTRACT=true

# Use deterministic mock query clients.
USE_MOCK_QUERY=true

# Use the deterministic mock page fetcher for local crawl runs.
USE_MOCK_FETCH=true

# Maximum deduplicated seed URLs crawled per alum.

# Maximum in-flight crawler requests across all hosts.
CRAWL_GLOBAL_CONCURRENCY=50

# Maximum concurrent crawler requests to one host.
CRAWL_PER_HOST_CONCURRENCY=4
